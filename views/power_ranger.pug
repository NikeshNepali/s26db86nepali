extends layout

block content
  h1= 'Search Result: ' + title
  - rangers = results  
  div(class="container_fluid")
    div(class="row")
    - index = 0
      each ranger in rangers
        div(class="col-sm-2" onclick=`buy(${index})`)
          p #{ranger.rangerColor} #{ranger.rangerPower} #{ranger.rangerStrength}
          - index++
  script.
    var rangers = results 
    function buy(index){
      alert("You bought " + rangers[index])
    }